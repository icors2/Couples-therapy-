## Copy this file to local.properties and fill in your values.
## local.properties is gitignored and must never be committed.

sdk.dir=/path/to/Android/sdk

# Supabase project (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth Web Client ID (used with Supabase Google provider)
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Optional: OpenAI key for local/debug builds (prefer Edge Function secrets in production)
OPENAI_API_KEY=
